[
  { "name": "fr24_id",           "type": "STRING",    "mode": "REQUIRED", "description": "FR24 internal flight ID; primary dedup key" },
  { "name": "flight_number",     "type": "STRING",    "mode": "REQUIRED" },
  { "name": "airline_iata",      "type": "STRING",    "mode": "NULLABLE" },
  { "name": "route",             "type": "STRING",    "mode": "REQUIRED", "description": "ORIGIN-DEST e.g. SVO-SGN" },
  { "name": "origin_iata",       "type": "STRING",    "mode": "REQUIRED" },
  { "name": "destination_iata",  "type": "STRING",    "mode": "REQUIRED" },
  { "name": "flight_date",       "type": "DATE",      "mode": "REQUIRED", "description": "Partition column; arrival date in Vietnam time" },
  { "name": "scheduled_dep_at",  "type": "TIMESTAMP", "mode": "NULLABLE" },
  { "name": "actual_dep_at",     "type": "TIMESTAMP", "mode": "NULLABLE" },
  { "name": "scheduled_arr_at",  "type": "TIMESTAMP", "mode": "NULLABLE" },
  { "name": "actual_arr_at",     "type": "TIMESTAMP", "mode": "NULLABLE" },
  { "name": "aircraft_code",     "type": "STRING",    "mode": "NULLABLE" },
  { "name": "aircraft_reg",      "type": "STRING",    "mode": "NULLABLE" },
  { "name": "pax_est",           "type": "INT64",     "mode": "NULLABLE" },
  { "name": "loaded_at",         "type": "TIMESTAMP", "mode": "REQUIRED", "description": "Ingest timestamp; loader MERGEs on fr24_id so each table has one row per flight" }
]
