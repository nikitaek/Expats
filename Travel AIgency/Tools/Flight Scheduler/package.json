{
  "name": "flight-scheduler",
  "version": "2.0.0",
  "private": true,
  "description": "FR24-only CIS→Vietnam flight pipeline",
  "type": "module",
  "scripts": {
    "daily": "node scripts/v2-daily-run.mjs",
