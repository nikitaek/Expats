{
  "name": "flight-scheduler",
  "version": "1.0.0",
  "private": true,
  "description": "Vietnam inbound flight scheduler for Russian-speaking tourist origins",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "prefetch:future": "node scripts/prefetch-future.mjs",
    "prefetch:history": "node scripts/prefetch-history.mjs",
    "prefetch:rolling": "node scripts/prefetch-rolling.mjs",
    "audit:api": "node scripts/audit-api-coverage.mjs",
    "fill:gap": "node scripts/fill-gap.mjs",
    "fill:gap:stack": "node scripts/fill-gap-aviationstack.mjs",
    "scan:aircraft": "node scripts/scan-aircraft.mjs",
    "fetch:fr24": "node scripts/fetch-fr24-cis-vn.mjs",
    "test:fr24": "node scripts/test-fr24-strategies.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
