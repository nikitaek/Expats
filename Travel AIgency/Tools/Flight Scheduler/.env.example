# Aviation Edge API key: https://aviation-edge.com/developers/
AVIATION_EDGE_API_KEY=your_api_key_here
PORT=3847
# Days ahead before flightsFuture works (provider default: 7)
# FUTURE_MIN_DAYS_AHEAD=7

# Flightradar24 API — https://fr24api.flightradar24.com/
# FR24_API_TOKEN=your_token_here
# FR24_REQUEST_DELAY_MS=3000

# Aviationstack (APILayer) — near-term gap fill script only
# AVIATIONSTACK_ACCESS_KEY=your_key_here
# AVIATIONSTACK_DELAY_MS=11000
