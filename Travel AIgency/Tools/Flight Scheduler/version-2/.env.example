FR24_API_TOKEN=
FR24_REQUEST_DELAY_MS=3500
FR24_PAGE_SIZE=2000
# Earliest calendar day your FR24 plan returns (subscription start date, UTC)
FR24_DATA_FROM=2026-05-07

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_BUCKET=tour-aigency-flights
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Option A: API token → S3 (Access Key ID = token id, Secret = SHA-256 of token value)
R2_API_TOKEN_ID=
CLOUDFLARE_API_TOKEN=

# Option B: classic keys from R2 dashboard "Manage API Tokens"
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

BIGQUERY_PROJECT=
BIGQUERY_DATASET=vn_flights
GOOGLE_APPLICATION_CREDENTIALS=
